window.openModalJornada = async function() {
  try {
    const jornada = await db.getJornada();

    const dias = [
      { k: 'dom', l: 'Dom' },
      { k: 'seg', l: 'Seg' },
      { k: 'ter', l: 'Ter' },
      { k: 'qua', l: 'Qua' },
      { k: 'qui', l: 'Qui' },
      { k: 'sex', l: 'Sex' },
      { k: 'sab', l: 'Sáb' }
    ];

    showModal('modal-jornada', 'Jornada de Trabalho', `
      <p style="font-size:12px;color:var(--text2);margin-bottom:16px">
        Defina as horas disponíveis por dia.
        <strong style="color:var(--text)">0 = dia desativado.</strong>
      </p>

      <div style="display:grid;grid-template-columns:repeat(7,1fr);gap:8px">
        ${dias.map(d => {
          const hrs = Number(jornada?.[d.k] ?? 0);
          const active = hrs > 0;

          return `
            <div style="text-align:center;background:var(--s2);border:1px solid ${active ? 'var(--cyan)' : 'var(--border)'};border-radius:var(--r);padding:12px 6px">
              <div style="font-size:10px;font-weight:700;color:${active ? 'var(--cyan)' : 'var(--text3)'};font-family:'JetBrains Mono',monospace;margin-bottom:8px">
                ${d.l}
              </div>
              <input
                id="jr-${d.k}"
                type="number"
                min="0"
                max="24"
                step=".5"
                value="${hrs}"
                class="finp"
                style="padding:8px 4px;text-align:center;font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:700"
              >
            </div>
          `;
        }).join('')}
      </div>
    `, async () => {
      const data = {};
      dias.forEach(d => {
        data[d.k] = parseFloat($(`jr-${d.k}`)?.value) || 0;
      });

      await db.saveJornada(data);
      toast('Jornada salva!', 'ok');
      return true;
    });

  } catch (e) {
    console.error('Erro ao abrir jornada:', e);
    toast('Erro ao abrir jornada de trabalho.', 'err');
  }
};

window.exportBackup = async function() {
  try {
    const bkp=await db.exportarBackup();
    const blob=new Blob([JSON.stringify(bkp,null,2)],{type:'application/json'});
    const url=URL.createObjectURL(blob);
    const a=document.createElement('a'); a.href=url; a.download=`backup_progprod_${today()}.json`;
    document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
    toast('Backup exportado!','ok');
  } catch(e) { toast('Erro: '+e.message,'err'); }
};

window.importBackup = function(input) {
  if(!input.files.length) return;
  if(!confirm('Importar este backup? Isso NÃO apagará dados existentes — apenas adicionará os registros do arquivo.')) return;
  const reader=new FileReader();
  reader.onload=async function(e){
    try {
      const bkp=JSON.parse(e.target.result);
      let count=0;
      if(bkp.registros?.length) { for(const r of bkp.registros){ const {id,...data}=r; await db.addRegistro(data); count++; } }
      toast(`${count} registros importados!`,'ok');
    } catch(err){ toast('Erro ao importar: '+err.message,'err'); }
  };
  reader.readAsText(input.files[0]);
  input.value='';
};

// ================================================================
//  USUÁRIOS
// ================================================================
let usersData=[];

function renderUsuarios() {
  const p=$('panel-usuarios'); if(!p) return;
  db.onUsuarios(users=>{ usersData=users; drawUsers(); });
}

function drawUsers() {
  const p=$('panel-usuarios'); if(!p) return;
  const canAdmin=currentUser?.nivel==='admin';
  p.innerHTML=`
    <div class="pg-hd">
      <h1 class="pg-title">👤 Usuários e Permissões</h1>
      <div class="pg-sub">${usersData.length} usuários cadastrados</div>
    </div>
    ${canAdmin?`<div class="toolbr">
      <button class="btn btn-primary" onclick="openModalNovoUsuario()">+ Criar Usuário</button>
    </div>`:''}
    <div class="tbl-wrap">
      <table>
        <thead><tr><th>Usuário</th><th>Email</th><th>Nível</th><th>Status</th>${canAdmin?'<th>Ações</th>':''}</tr></thead>
        <tbody>
          ${usersData.map(u=>{
            const ri=NIVEL_META[u.nivel]||NIVEL_META.visualizacao;
            return `<tr>
              <td>
                <div style="display:flex;align-items:center;gap:10px">
                  <div style="width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;background:${ri.bg};color:${ri.color};font-family:'JetBrains Mono',monospace;flex-shrink:0">${(u.nome||u.email||'?')[0].toUpperCase()}</div>
                  <div>
                    <div style="font-size:12px;font-weight:700">${u.nome||'—'}</div>
                    <div style="font-size:10px;color:var(--text3);font-family:'JetBrains Mono',monospace">${u.cargo||''}</div>
                  </div>
                </div>
              </td>
              <td style="font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--text2)">${u.email||'—'}</td>
              <td><span class="badge" style="background:${ri.bg};color:${ri.color};border:1px solid ${ri.color}33;font-size:9px">${ri.icon} ${ri.label}</span></td>
              <td><span class="badge ${u.ativo?'b-green':'b-mute'}" style="font-size:9px">${u.ativo?'● Ativo':'○ Inativo'}</span></td>
              ${canAdmin?`<td>
                <div class="tbl-actions">
                  <button class="btn btn-ghost btn-sm" onclick="openModalEditUsuario('${u.uid}')">✏️ Editar</button>
                  <button class="btn ${u.ativo?'btn-warn':'btn-primary'} btn-sm" onclick="toggleUserAtivo('${u.uid}',${!u.ativo})">${u.ativo?'🔒 Suspender':'🔓 Ativar'}</button>
                </div>
              </td>`:''}
            </tr>`;
          }).join('')||`<tr><td colspan="5"><div class="empty-st"><div class="ei">👤</div>Nenhum usuário</div></td></tr>`}
        </tbody>
      </table>
    </div>
    <div style="margin-top:18px;background:var(--s1);border:1px solid var(--border);border-radius:var(--r2);padding:18px">
      <div style="font-family:'JetBrains Mono',monospace;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text3);margin-bottom:14px">PERMISSÕES POR NÍVEL</div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px">
        ${Object.entries(PERMS).map(([nivel,perms])=>{
          const ri=NIVEL_META[nivel]||NIVEL_META.visualizacao;
          return `<div style="background:var(--s2);border:1px solid var(--border);border-radius:var(--r);padding:12px">
            <div style="font-size:11px;font-weight:700;color:${ri.color};margin-bottom:8px">${ri.icon} ${ri.label}</div>
            ${perms.map(m=>`<div style="font-size:10px;color:var(--text3);padding:2px 0;font-family:'JetBrains Mono',monospace">✓ ${m}</div>`).join('')}
          </div>`;
        }).join('')}
      </div>
    </div>`;
}

window.openModalNovoUsuario = function() {
  showModal('modal-user', 'Criar Novo Usuário', `
    <div class="form-row fr2">
      <div class="fgrp"><label class="flbl">Nome completo *</label><input id="u-nome" class="finp" placeholder="João Silva"></div>
      <div class="fgrp"><label class="flbl">Cargo</label><input id="u-cargo" class="finp" placeholder="Operador, Planejador..."></div>
      <div class="fgrp"><label class="flbl">Email *</label><input id="u-email" class="finp" type="email" placeholder="joao@empresa.com"></div>
      <div class="fgrp"><label class="flbl">Senha inicial *</label><input id="u-senha" class="finp" type="password" placeholder="Mín. 6 caracteres"></div>
      <div class="fgrp"><label class="flbl">Nível de acesso *</label>
        <select id="u-nivel" class="fsel">
          <option value="visualizacao">Visualização</option>
          <option value="operador">Operador</option>
          <option value="planejamento">Planejamento</option>
          <option value="admin">Administrador</option>
        </select>
      </div>
    </div>
    <div id="u-err" class="lf-error" style="margin-top:8px"></div>
    <div style="margin-top:12px;font-size:11px;color:var(--text3);background:var(--s2);border-radius:var(--r);padding:10px 12px">
      ⚠️ O usuário receberá acesso imediato com as credenciais informadas. Oriente-o a alterar a senha no primeiro acesso.
    </div>`,
  async () => {
    const { criarUsuario } = await import('./auth.js');
    const nome=$('u-nome').value.trim(), email=$('u-email').value.trim();
    const senha=$('u-senha').value, nivel=$('u-nivel').value;
    const err=$('u-err');
    if(!nome){err.textContent='Nome obrigatório.';err.classList.add('on');return false;}
    if(!email){err.textContent='Email obrigatório.';err.classList.add('on');return false;}
    if(senha.length<6){err.textContent='Senha deve ter no mínimo 6 caracteres.';err.classList.add('on');return false;}
    try {
      const btn=$('modal-save-btn'); if(btn){btn.disabled=true;btn.textContent='Criando...';}
      await criarUsuario(email, senha, {
        nome, email, nivel, cargo:$('u-cargo').value.trim(), ativo:true
      });
      toast('Usuário criado com sucesso!','ok');
      return true;
    } catch(e){
      err.textContent = e.code==='auth/email-already-in-use'?'Este email já está em uso.':'Erro: '+e.message;
      err.classList.add('on');
      const btn=$('modal-save-btn'); if(btn){btn.disabled=false;btn.textContent='Salvar';}
      return false;
    }
  });
};

window.openModalEditUsuario = function(uid) {
  const u=usersData.find(x=>x.uid===uid); if(!u) return;
  showModal('modal-user-edit','Editar Usuário',`
    <div class="form-row fr2">
      <div class="fgrp"><label class="flbl">Nome</label><input id="ue-nome" class="finp" value="${u.nome||''}"></div>
      <div class="fgrp"><label class="flbl">Cargo</label><input id="ue-cargo" class="finp" value="${u.cargo||''}"></div>
      <div class="fgrp"><label class="flbl">Nível de acesso</label>
        <select id="ue-nivel" class="fsel">
          ${['visualizacao','operador','planejamento','admin'].map(n=>`<option value="${n}" ${u.nivel===n?'selected':''}>${NIVEL_META[n]?.label||n}</option>`).join('')}
        </select>
      </div>
    </div>`,
  async ()=>{
    await db.updateUsuario(uid,{nome:$('ue-nome').value.trim(),cargo:$('ue-cargo').value.trim(),nivel:$('ue-nivel').value});
    toast('Usuário atualizado!','ok'); return true;
  });
};

window.toggleUserAtivo = async function(uid, ativo) {
  await db.updateUsuario(uid,{ativo});
  toast(ativo?'Usuário ativado.':'Usuário suspenso.','ok');
};

// ================================================================
//  MODAL & CONFIRM ENGINE
// ================================================================
function showModal(id, title, bodyHtml, onSave) {
  let el=$('overlay-modal');
  if(el) el.remove();
  el=document.createElement('div');
  el.id='overlay-modal'; el.className='overlay';
  el.innerHTML=`
    <div class="modal">
      <div class="modal-hd">
        <div class="modal-title">${title}</div>
        <button class="modal-close" onclick="closeModal()">✕</button>
      </div>
      <div class="modal-bd">${bodyHtml}</div>
      <div class="modal-ft">
        <button class="btn btn-ghost" onclick="closeModal()">Cancelar</button>
        <button class="btn btn-primary" id="modal-save-btn" onclick="handleModalSave()">Salvar</button>
      </div>
    </div>`;
  document.body.appendChild(el);
  el.addEventListener('click', e=>{ if(e.target===el) closeModal(); });
  window._modalSaveFn = onSave;
}
window.closeModal=function(){const el=$('overlay-modal');if(el)el.remove();};
window.handleModalSave=async function(){
  if(window._modalSaveFn){
    const ok=await window._modalSaveFn();
    if(ok!==false) closeModal();
  }
};

function showConfirm(msg, onOk) {
  let el=$('overlay-confirm');
  if(el) el.remove();
  el=document.createElement('div');
  el.id='overlay-confirm'; el.className='overlay';
  el.innerHTML=`<div class="modal" style="max-width:400px">
    <div class="modal-hd"><div class="modal-title">Confirmar</div></div>
    <div class="modal-bd"><p style="font-size:13px;line-height:1.6">${msg}</p></div>
    <div class="modal-ft">
      <button class="btn btn-ghost" onclick="this.closest('.overlay').remove()">Cancelar</button>
      <button class="btn btn-danger" onclick="handleConfirm()">Confirmar</button>
    </div>
  </div>`;
  document.body.appendChild(el);
  window._confirmFn=onOk;
}
window.handleConfirm=async function(){await window._confirmFn?.();const el=$('overlay-confirm');if(el)el.remove();};

// ================================================================
//  BOOT
// ================================================================
function updateClock() {
  const now=new Date();
  const t=$('tb-time'), d=$('tb-date');
  if(t) t.textContent=now.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});
  if(d) d.textContent=now.toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit'});
}

// Wire up globals for HTML onclick handlers
window.navigate       = navigate;
window.toggleSidebar  = toggleSidebar;
window.toast          = toast;
window.progSearch_set = v=>{ progSearch=v; renderProgramacao(); };
window.NIVEL_META     = NIVEL_META;
window.PERMS          = PERMS;
window.toggleTopbarMenu = function(){ $('topbar-menu')?.classList.toggle('on'); };
window.openConfiguracoesTop = function(){ $('topbar-menu')?.classList.remove('on'); navigate('configuracoes'); };
window.renderFichaTecnica = renderFichaTecnica;
window.renderInsumosMaq = renderInsumosMaq;
window.renderInsumosGeral = renderInsumosGeral;
window.renderRealizado = renderRealizado;

// Init auth
document.addEventListener('DOMContentLoaded', ()=>{
  updateClock(); setInterval(updateClock, 15000);

  $('lf-btn')?.addEventListener('click', handleLogin);
  $('lf-pass')?.addEventListener('keydown', e=>{ if(e.key==='Enter') handleLogin(); });

  initAuth(
    async (user) => { await bootApp(user); },
    () => { showLogin(); db.cancelAllListeners(); }
  );

  $('lf-btn')?.removeAttribute('disabled');
});
