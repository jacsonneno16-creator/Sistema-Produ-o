function renderConfiguracoes() {
  const p = $('panel-configuracoes'); if(!p) return;

  p.innerHTML = `
    <div class="pg-hd">
      <h1 class="pg-title">⚙️ Configurações</h1>
      <div class="pg-sub">Jornada, backup, máquinas e importação de dados</div>
    </div>

    <div class="g-auto">
      ${[
        {icon:'🕐',title:'Jornada de Trabalho',desc:'Horas por dia da semana',color:'var(--cyan)',action:'openModalJornada()'},
        {icon:'📥',title:'Importar Base Máquina x Produto',desc:'Cadastra máquinas automaticamente e salva tempos de produção',color:'var(--purple)',action:"document.getElementById('imp-base-maq').click()"},
        {icon:'📦',title:'Importar Estoque',desc:'Lê o arquivo de estoque e salva a base no Firebase',color:'var(--green)',action:"document.getElementById('imp-estoque').click()"},
        {icon:'🧾',title:'Importar Pedidos',desc:'Lê o arquivo de pedidos e salva a base no Firebase',color:'var(--amber)',action:"document.getElementById('imp-pedidos').click()"},
        {icon:'📈',title:'Importar Escadinha',desc:'Lê a projeção de vendas e salva a base no Firebase',color:'var(--cyan)',action:"document.getElementById('imp-escadinha').click()"},
        {icon:'💾',title:'Backup / Exportar',desc:'Exportar todos os dados em JSON',color:'var(--green)',action:'exportBackup()'},
        {icon:'🏭',title:'Máquinas',desc:'Abrir cadastro de máquinas',color:'var(--purple)',action:"navigate('maquinas')"},
      ].map(c=>`
        <div class="card" style="cursor:pointer;transition:border-color .2s" onclick="${c.action}"
          onmouseover="this.style.borderColor='${c.color}'" onmouseout="this.style.borderColor='var(--border)'">
          <div class="card-bd">
            <div style="font-size:32px;margin-bottom:12px">${c.icon}</div>
            <div style="font-size:14px;font-weight:700;margin-bottom:6px">${c.title}</div>
            <div style="font-size:12px;color:var(--text2)">${c.desc}</div>
          </div>
        </div>`).join('')}
    </div>

    <input type="file" id="imp-base-maq" accept=".xlsx,.xls" style="display:none" onchange="handleImportBaseMaquina(this)">
    <input type="file" id="imp-estoque" accept=".xlsx,.xls" style="display:none" onchange="handleImportEstoque(this)">
    <input type="file" id="imp-pedidos" accept=".xlsx,.xls" style="display:none" onchange="handleImportPedidos(this)">
    <input type="file" id="imp-escadinha" accept=".xlsx,.xls" style="display:none" onchange="handleImportEscadinha(this)">
    <input type="file" id="cfg-import" accept=".json" style="display:none" onchange="importBackup(this)">
  `;
}

window.handleImportBaseMaquina = async function(input) {
  const file = input?.files?.[0];
  if (!file) return;

  try {
    toast('Importando base máquina x produto...', 'ok');
    const mod = await import('./importadores.js');
    const r = await mod.importarBaseMaquinaProduto(file);
    toast(`Base importada! ${r.totalLinhas} linhas · ${r.totalMaquinas} máquinas`, 'ok');
    input.value = '';
  } catch (e) {
    console.error(e);
    toast('Erro ao importar base máquina x produto: ' + e.message, 'err');
    input.value = '';
  }
};

window.handleImportEstoque = async function(input) {
  const file = input?.files?.[0];
