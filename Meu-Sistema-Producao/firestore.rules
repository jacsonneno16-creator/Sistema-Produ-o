rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()   { return request.auth != null; }
    function nivel()    { return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.nivel; }
    function isAtivo()  { return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.ativo == true; }
    function isAdmin()  { return isAuth() && isAtivo() && nivel() == 'admin'; }
    function isPlan()   { return isAuth() && isAtivo() && nivel() in ['admin','planejamento']; }
    function isOper()   { return isAuth() && isAtivo() && nivel() in ['admin','planejamento','operador']; }
    function isAny()    { return isAuth() && isAtivo(); }

    // ── Coleções globais (não por loja) ──
    match /usuarios/{uid} {
      allow read:  if isAuth() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }
    match /lojas/{lojaId} {
      allow read: if isAny();
      allow write: if isAny(); // qualquer usuário pode criar/editar lojas
    }

    // ── Todas as coleções operacionais ficam dentro da loja ──
    match /lojas/{lojaId}/{colecao}/{docId} {
      allow read: if isAny();
      allow write: if isOper(); // operadores podem salvar apontamentos
    }

    // Apontamentos dentro da loja — escrita permitida a operadores (redundante mas explícito)
    match /lojas/{lojaId}/apontamentos_producao/{docId} {
      allow read: if isAny();
      allow write: if isOper();
    }

    // ── Coleções legadas (raiz) — mantidas para compatibilidade durante migração ──
    match /registros/{id}             { allow read: if isAny(); allow write: if isPlan(); }
    match /maquinas/{id}              { allow read: if isAny(); allow write: if isPlan(); }
    match /produtos/{id}              { allow read: if isAny(); allow write: if isPlan(); }
    match /insumos/{id}               { allow read: if isAny(); allow write: if isPlan(); }
    match /fichas/{id}                { allow read: if isAny(); allow write: if isPlan(); }
    match /fichaTecnica/{id}          { allow read: if isAny(); allow write: if isPlan(); }
    match /fichaTecnicaData/{id}      { allow read: if isAny(); allow write: if isPlan(); }
    match /setup_maquinas/{id}        { allow read: if isAny(); allow write: if isPlan(); }
    match /apontamentos/{id}          { allow read: if isAny(); allow write: if isOper(); }
    match /apontamentos_producao/{id} { allow read: if isAny(); allow write: if isOper(); }
    match /programacao_producao/{id}  { allow read: if isAny(); allow write: if isPlan(); }
    match /Producao/{id}              { allow read: if isAny(); allow write: if isPlan(); }
    match /auditoria/{id}             { allow read: if isAdmin(); allow write: if isAuth(); }
    match /configuracoes/{id}         { allow read: if isAny(); allow write: if isPlan(); }
    match /funcionarios_producao/{id} { allow read: if isAny(); allow write: if isPlan(); }
  }
}
